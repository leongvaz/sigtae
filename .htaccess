<IfModule mod_rewrite.c>
    RewriteEngine On
    # Evita bucle: tras la primera reescritura la ruta relativa ya es public/...
    RewriteRule ^public/ - [L]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Subida de evidencias: sin límite práctico de tamaño (ajustar en php.ini si el hosting lo ignora)
<IfModule mod_php.c>
    php_value upload_max_filesize 2048M
    php_value post_max_size       2048M
    php_value max_file_uploads    100
    php_value memory_limit        512M
    php_value max_execution_time  600
    php_value max_input_time      600
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 2048M
    php_value post_max_size       2048M
    php_value max_file_uploads    100
    php_value memory_limit        512M
    php_value max_execution_time  600
    php_value max_input_time      600
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 2048M
    php_value post_max_size       2048M
    php_value max_file_uploads    100
    php_value memory_limit        512M
